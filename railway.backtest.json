{
  "$schema": "https://railway.app/railway.schema.json",
  "build": {
    "builder": "DOCKERFILE",
    "dockerfilePath": "Dockerfile.backtest"
  },
  "deploy": {
    "startCommand": "node --max-old-space-size=7168 --expose-gc scripts/run-all-strategies-fast.mjs",
    "restartPolicyType": "NEVER",
    "numReplicas": 1
  }
}
